# =============================================
#  OrySaaS — root .gitignore (monorepo)
# =============================================

# --- Éditeurs / IDE ---
.idea/
.vscode/
*.swp
*.swo
desktop.ini

# --- Claude Code ---
.claude/

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db

# --- Node / package managers ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# --- Logs ---
logs/
*.log
*.log.*
pids/
*.pid
*.seed

# --- Environnement (garde les .env.example commités) ---
.env
.env.*
!.env.example

# --- Build / dist / cache ---
build/
dist/
.next/
.nuxt/
.output/
coverage/
.nyc_output/
*.tsbuildinfo
.cache/
.tmp/
.temp/
tmp/
temp/

# --- Uploads / données locales ---
uploads/
*.sqlite*
*.db

# --- Lint ---
.eslintcache